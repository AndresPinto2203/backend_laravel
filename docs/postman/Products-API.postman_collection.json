{
  "info": {
    "name": "Products API – Prueba técnica",
    "description": "Colección Postman para la API de productos con autenticación JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin_123456\"\n}"
            },
            "description": "Obtiene un token JWT usando el usuario admin seed."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Lista paginada de productos."
          },
          "response": []
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test product\",\n  \"description\": \"Descripción de prueba\",\n  \"price\": 100.5,\n  \"currency_id\": 1,\n  \"tax_cost\": 21,\n  \"manufacturing_cost\": 50\n}"
            },
            "description": "Crea un nuevo producto en la divisa indicada."
          },
          "response": []
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1"
              ]
            },
            "description": "Obtiene un producto por ID."
          },
          "response": []
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto actualizado\"\n}"
            },
            "description": "Actualiza parcialmente un producto existente."
          },
          "response": []
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1"
              ]
            },
            "description": "Elimina un producto por ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Product prices",
      "item": [
        {
          "name": "List product prices",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1/prices",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1",
                "prices"
              ]
            },
            "description": "Lista los precios de un producto en distintas divisas."
          },
          "response": []
        },
        {
          "name": "Create product price",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1/prices",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "1",
                "prices"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency_id\": 2,\n  \"price\": 90.25\n}"
            },
            "description": "Crea un nuevo precio para el producto en otra divisa."
          },
          "response": []
        }
      ]
    }
  ]
}
